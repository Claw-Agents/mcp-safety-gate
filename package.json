{
  "name": "mcp-safety-gate",
  "version": "1.0.0",
  "type": "module",
  "description": "Security middleware MCP server for OpenClaw",
  "main": "dist/index.js",
  "bin": {
    "safety-gate": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --outDir dist",
    "dev": "node --loader ts-node/esm src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --loader ts-node/esm tests/safetyGate.test.ts",
    "integration:harness": "npm run build && node --loader ts-node/esm scripts/integrationHarness.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "tsup": "^8.0.1",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
